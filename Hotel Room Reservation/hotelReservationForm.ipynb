    import sys
    from PyQt5.QtCore import QDate
    from datetime import date, timedelta
    from PyQt5.QtWidgets import QDialog, QApplication
    from hotelReservationForm import *
   
    class MyForm(QDialog):
        def __init__(self):
            super().__init__()
            self.ui = Ui_Dialog()
            self.ui.setupUi(self)
            self.ui.calendarWidget.selectionChanged.connect(self.disDate)
            self.ui.spinBox.valueChanged.connect(self.disNoDays)
            self.ui.comboBox.activated.connect(self.disRoomType)
            self.ui.pushButtonCalculateRoomRent.clicked.connect(self.disPrice)
            self.show()
    
        def disDate(self):
            number = 2
            now = QDate.currentDate()
            date = self.ui.calendarWidget.selectedDate()
            if date >= now:
                date = self.ui.calendarWidget.selectedDate()
                new_date = date.toPyDate()
                self.ui.dateOfReservationInfo.setText("Reservation date: " + str(new_date))
            else:
                self.ui.dateOfReservationInfo.setText("Can't place reservation!!!")
  
        def disNoDays(self):
            number = self.ui.spinBox.text()
            self.ui.noOfDaysInfo.setText("Number of days: " + str(number))
   
        def disRoomType(self):
            room = self.ui.comboBox.currentText()
            self.ui.roomTypeInfo.setText("Room Type: " + str(room))
   
        def disPrice(self):
            if self.ui.comboBox.currentText() == "Single Room":
                days = self.ui.spinBox.text()
                noOfDays = 0
                noOfDays += int(days)
                singleRoom = self.ui.comboBox.currentText()
                singleRoom = 1000
                totalPrice = noOfDays * singleRoom
                self.ui.roomRentInfo.setText("Total Price: R" + str(totalPrice))
   
            elif self.ui.comboBox.currentText() == "Double Room":
                days = self.ui.spinBox.text()
                noOfDays = 0
                noOfDays += int(days)
                doubleRoom = self.ui.comboBox.currentText()
                doubleRoom = 2000
                totalPrice = noOfDays * doubleRoom
                self.ui.roomRentInfo.setText("Total Price: R" + str(totalPrice))
   
            elif self.ui.comboBox.currentText() == "Family Room":
                days = self.ui.spinBox.text()"
                noOfDays = 0"
                noOfDays += int(days)"
                familyRoom = self.ui.comboBox.currentText()"
                familyRoom = 3000"
                totalPrice = noOfDays * familyRoom"
                self.ui.roomRentInfo.setText("Total Price: R" + str(totalPrice))
   
    if __name__ == "__main__":
        app = QApplication(sys.argv)
        myApp = MyForm()
        myApp.show()
        sys.exit(app.exec_())